# Local: SQLite em arquivo (placeholder, mas necessario p/ Prisma validar)
DATABASE_URL="file:./dev.db"

# Producao: Turso (libSQL). Quando essas duas vars estiverem setadas,
# o Prisma usa o adaptador libsql automaticamente.
# TURSO_DATABASE_URL="libsql://<seu-db>.turso.io"
# TURSO_AUTH_TOKEN="<seu-token>"

# Hunter.io — busca de e-mail por nome + dominio da empresa
# Obter em: https://hunter.io/api-keys
# HUNTER_API_KEY="<sua-chave>"

# Snov.io — fallback para busca de e-mail (150 créditos/mês grátis)
# Obter em: https://app.snov.io/api-setting
# SNOV_CLIENT_ID="<seu-id>"
# SNOV_CLIENT_SECRET="<seu-segredo>"
